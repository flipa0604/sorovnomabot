# Telegram (BotFather)
BOT_TOKEN=123456:ABC-DEF...

# Kanal: @username yoki -100... (supergroup/channel ID)
REQUIRED_CHANNEL_ID=@your_channel_username
# Yoki: REQUIRED_CHANNEL_ID=-1001234567890

# Instagram profil havolasi (bot Instagramga kirishni tekshira olmaydi — foydalanuvchi havolani ochib tasdiqlaydi)
INSTAGRAM_PROFILE_URL=https://www.instagram.com/your_profile/

# Adminlar: Telegram user ID lar, vergul bilan
ADMIN_IDS=123456789,987654321

# SQLite (lokal) yoki PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sorovnomabot

# Ixtiyoriy: log darajasi
LOG_LEVEL=INFO

# Web-admin (tuman / maktab / direktorlar): python run_admin_web.py
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=ozgartiring
WEB_ADMIN_SECRET=uzun-tasodifiy-maxfiy-kalit
WEB_ADMIN_HOST=127.0.0.1

# Nginx proxy_pass bilan mos (deploy/nginx-admin.bimu.uz.conf → 8002)
WEB_ADMIN_PORT=8002

# Veb-admin ochiq domeni (HTTPS). Telegram Web App tugmasi va initData tekshiruvi uchun.
# Masalan: https://admin.bimu.uz — oxirida / qo'ymang.
WEB_ADMIN_PUBLIC_URL=https://admin.bimu.uz
